<script>
  // ── COUNTDOWN ──
  function updateCountdown() {
    const now = new Date();
    const close = new Date(now);
    close.setHours(20, 0, 0, 0);
    let diff = Math.max(0, close - now);
    const h = Math.floor(diff / 3600000); diff -= h * 3600000;
    const m = Math.floor(diff / 60000);   diff -= m * 60000;
    const s = Math.floor(diff / 1000);
    document.getElementById('cd-h').textContent = String(h).padStart(2,'0');
    document.getElementById('cd-m').textContent = String(m).padStart(2,'0');
    document.getElementById('cd-s').textContent = String(s).padStart(2,'0');
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // ── TURNOUT BAR ──
  setTimeout(() => {
    const pct = (12847 / 28400 * 100).toFixed(1);
    document.getElementById('turnout-bar').style.width = pct + '%';
  }, 300);

  // ── CANDIDATE SELECTION ──
  let selected = null;
  let voted = false;
  const cards = document.querySelectorAll('.candidate-card');

  cards.forEach(card => {
    card.addEventListener('click', () => selectCandidate(card));
    card.addEventListener('keydown', e => {
      if ((e.key === 'Enter' || e.key === ' ') && !voted) {
        e.preventDefault();
        selectCandidate(card);
      }
    });
  });

  function selectCandidate(card) {
    if (voted) return;
    cards.forEach(c => { c.classList.remove('selected'); c.setAttribute('aria-checked','false'); });
    card.classList.add('selected');
    card.setAttribute('aria-checked','true');
    selected = parseInt(card.dataset.id);
    document.getElementById('btn-vote').disabled = false;
  }

  // ── VOTE SUBMISSION ──
  document.getElementById('btn-vote').addEventListener('click', submitVote);

  function submitVote() {
    if (selected === null || voted) return;
    voted = true;
    document.getElementById('btn-vote').disabled = true;
    document.getElementById('btn-vote').textContent = 'Submitting…';

    // simulate server delay
    setTimeout(() => {
      revealResults();
    }, 900);
  }

  function revealResults() {
    // simulated vote tallies (including the user's just-cast vote)
    const totals = [3812, 2941, 2207, 3887];
    totals[selected] += 1;
    const sum = totals.reduce((a,b) => a+b, 0);

    cards.forEach((card, i) => {
      card.classList.remove('selected');
      if (i === selected) {
        card.classList.add('voted-winner');
      } else {
        card.classList.add('voted-other');
      }
      const pct = (totals[i] / sum * 100).toFixed(1);
      document.getElementById('pct-' + i).textContent = pct + '%';
      setTimeout(() => {
        document.getElementById('bar-' + i).style.width = pct + '%';
      }, 100 + i * 80);
    });

    document.getElementById('vote-action').style.display = 'none';
    const banner = document.getElementById('success-banner');
    banner.classList.add('visible');
    document.getElementById('receipt-code').textContent = 'Receipt #' + Math.random().toString(36).substring(2,10).toUpperCase();

    // bump turnout display
    const newCount = 12848;
    document.getElementById('turnout-num').textContent = newCount.toLocaleString();
    document.getElementById('turnout-bar').style.width = (newCount / 28400 * 100).toFixed(2) + '%';
  }

  // ── POLL OPTIONS ──
  document.querySelectorAll('.poll-option').forEach(opt => {
    opt.addEventListener('click', () => {
      const pollId = opt.dataset.poll;
      document.querySelectorAll(`.poll-option[data-poll="${pollId}"]`).forEach(o => {
        o.classList.remove('selected');
        o.setAttribute('aria-checked','false');
      });
      opt.classList.add('selected');
      opt.setAttribute('aria-checked','true');
    });
    opt.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); opt.click(); }
    });
  });
</script>
